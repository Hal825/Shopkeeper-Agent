"""
电商问数系统 - 核心实体示例与必备知识

本文件用于帮助理解系统中的五个核心实体以及相关的必备知识。
通过一个完整的电商场景示例，展示实体如何协作完成用户问数。

使用场景：
    用户问："华东地区2024年1月的GMV是多少？"
    系统如何通过这五个实体理解问题并生成SQL。
"""

from dataclasses import dataclass
from typing import Any, Optional


# ============================================================
# 第一部分：五个核心实体定义
# ============================================================

@dataclass
class TableInfo:
    """表信息实体 - 描述数据在哪个容器里"""
    id: str          # 表唯一标识，如 "dim_region"
    name: str        # 表名，如 "dim_region"
    role: str        # 表角色：dim（维度表）/ fact（事实表）
    description: str # 表业务描述


@dataclass
class ColumnInfo:
    """字段信息实体 - 描述字段的结构和含义"""
    id: str              # 唯一标识：表名.字段名，如 "dim_region.region_name"
    name: str            # 字段名，如 "region_name"
    type: str            # 字段类型，如 varchar(50)，从DW查询
    role: str            # 字段角色：primary_key/foreign_key/dimension/measure
    examples: list[Any]  # 示例值，如 ["华东","华南"]，从DW查询
    description: str     # 字段业务描述
    alias: list[str]     # 别名，如 ["地区","区域","大区"]
    table_id: str        # 所属表名，关联 TableInfo.id
    sync: bool           # 是否同步真实取值到 Elasticsearch


@dataclass
class MetricInfo:
    """指标信息实体 - 描述业务概念（如GMV）"""
    id: str                    # 指标唯一标识，如 "GMV"
    name: str                  # 指标名，如 "GMV"
    description: str           # 指标描述
    relevant_columns: list[str]  # 关联的字段ID列表
    alias: list[str]           # 别名，如 ["成交总额","订单总额"]


@dataclass
class ColumnMetric:
    """字段-指标关联实体 - 记录指标与字段的映射关系"""
    column_id: str   # 字段ID，关联 ColumnInfo.id
    metric_id: str   # 指标ID，关联 MetricInfo.id


@dataclass
class ValueInfo:
    """字段取值实体 - 描述字段的具体取值（仅用于ES索引）"""
    id: str          # 唯一标识：{column_id}.{value}，如 "dim_region.region_name.华东"
    value: str       # 具体取值，如 "华东"
    column_id: str   # 所属字段ID，关联 ColumnInfo.id


# ============================================================
# 第二部分：必备知识 - DW 是什么
# ============================================================

"""
DW = Data Warehouse（数据仓库）

DW 与本系统的关系：
┌─────────────────────────────────────────────────────────────────┐
│                         DW（数据仓库）                           │
│  ┌─────────────────────────────────────────────────────────┐   │
│  │  真实的业务数据，如：                                     │   │
│  │  - dim_region 表：1,华东；2,华南；3,华北                  │   │
│  │  - fact_order 表：1001,1000,1；1002,2000,1               │   │
│  │  数据量巨大（TB/PB级）                                    │   │
│  └─────────────────────────────────────────────────────────┘   │
│                              ↓                                  │
│                    本系统实时查询以下信息：                       │
│                    - 字段类型（SHOW COLUMNS）                    │
│                    - 字段示例值（SELECT DISTINCT ... LIMIT 10）  │
└─────────────────────────────────────────────────────────────────┘
                              ↓
┌─────────────────────────────────────────────────────────────────┐
│                    Meta MySQL（元数据库）                        │
│  ┌─────────────────────────────────────────────────────────┐   │
│  │  描述数据的数据（元数据），如：                            │   │
│  │  - table_info：dim_region 是地区维度表                    │   │
│  │  - column_info：region_name 是 varchar 类型，存地区名      │   │
│  │  数据量很小（MB级）                                       │   │
│  └─────────────────────────────────────────────────────────┘   │
└─────────────────────────────────────────────────────────────────┘
"""


# ============================================================
# 第三部分：必备知识 - type 是什么
# ============================================================

"""
type = 数据库字段的数据类型，从 DW 查询得到

常见 type 值及用途：
┌─────────────────┬────────────────────────────────────────────┐
│ type            │ 说明与用途                                  │
├─────────────────┼────────────────────────────────────────────┤
│ int / bigint    │ 整数，可用于 SUM/AVG/比较                   │
│ decimal(10,2)   │ 小数，10位总长，2位小数，用于金额           │
│ varchar(50)     │ 变长字符串，最长50字符，用于名称/描述       │
│ date            │ 日期，可用于日期范围查询                    │
│ datetime        │ 日期时间，可用于精确时间查询                │
│ boolean         │ 布尔值，可用于条件判断                      │
└─────────────────┴────────────────────────────────────────────┘

系统根据 type 决定如何处理字段：
    if type.startswith("varchar"):
        # 字符串 → 可用 LIKE、包含查询
    elif type.startswith("int") or type.startswith("decimal"):
        # 数值 → 可用 SUM、AVG、比较大小
    elif type == "date":
        # 日期 → 可用日期范围查询
"""


# ============================================================
# 第四部分：必备知识 - role 是什么
# ============================================================

"""
role = 字段的业务角色，由用户在 YAML 配置文件中填写

常见 role 值：
┌───────────────┬─────────────┬─────────────────────────────────┐
│ role          │ 常见于      │ 用途                            │
├───────────────┼─────────────┼─────────────────────────────────┤
│ primary_key   │ 所有表      │ 唯一标识一行，用于 JOIN 关联     │
│ foreign_key   │ 事实表      │ 关联维度表，标记需要 JOIN        │
│ dimension     │ 维度表      │ 描述性字段，用于 WHERE/GROUP BY  │
│ measure       │ 事实表      │ 可计算数值，用于 SUM/AVG/MAX/MIN │
└───────────────┴─────────────┴─────────────────────────────────┘

系统根据 role 决定如何处理字段：
    if role == "primary_key":
        # 用于 JOIN 关联
    elif role == "foreign_key":
        # 标记需要关联其他表
    elif role == "dimension":
        # 用于 WHERE、GROUP BY
    elif role == "measure":
        # 用于 SUM、AVG 等聚合
"""


# ============================================================
# 第五部分：完整实例 - 电商问数场景
# ============================================================

"""
场景：用户问 "华东地区2024年1月的GMV是多少？"

数据准备：
┌─────────────────────────────────────────────────────────────────┐
│ dim_region（地区表）                                            │
│ ┌───────────┬─────────────┐                                    │
│ │ region_id │ region_name │                                    │
│ ├───────────┼─────────────┤                                    │
│ │ 1         │ 华东        │                                    │
│ │ 2         │ 华南        │                                    │
│ │ 3         │ 华北        │                                    │
│ └───────────┴─────────────┘                                    │
├─────────────────────────────────────────────────────────────────┤
│ dim_date（日期表）                                              │
│ ┌─────────┬──────┬───────┐                                    │
│ │ date_id │ year │ month │                                    │
│ ├─────────┼──────┼───────┤                                    │
│ │ 20240101│ 2024 │ 1     │                                    │
│ │ 20240102│ 2024 │ 1     │                                    │
│ └─────────┴──────┴───────┘                                    │
├─────────────────────────────────────────────────────────────────┤
│ fact_order（订单表）                                            │
│ ┌──────────┬───────────────┬───────────┬─────────┐            │
│ │ order_id │ order_amount  │ region_id │ date_id │            │
│ ├──────────┼───────────────┼───────────┼─────────┤            │
│ │ 1001     │ 1000.00       │ 1         │ 20240101│            │
│ │ 1002     │ 2000.00       │ 1         │ 20240101│            │
│ │ 1003     │ 1500.00       │ 2         │ 20240102│            │
│ └──────────┴───────────────┴───────────┴─────────┘            │
└─────────────────────────────────────────────────────────────────┘
"""


# ============================================================
# 第六部分：五个实体实例化
# ============================================================

# ---------- 1. TableInfo 实例 ----------
# 描述数据在哪个容器里
dim_region_table = TableInfo(
    id="dim_region",
    name="dim_region",
    role="dim",  # 维度表
    description="地区维度表，用于描述订单发生的地理区域信息。"
)

dim_date_table = TableInfo(
    id="dim_date",
    name="dim_date",
    role="dim",
    description="时间维度表，用于多时间粒度分析。"
)

fact_order_table = TableInfo(
    id="fact_order",
    name="fact_order",
    role="fact",  # 事实表
    description="订单事实表，记录订单数量和金额等核心指标。"
)


# ---------- 2. ColumnInfo 实例 ----------
# 描述字段的结构（type从DW来）和含义（role从YAML来）

# 地区表的地区名称字段（sync=true，需要同步取值到ES）
region_name_column = ColumnInfo(
    id="dim_region.region_name",
    name="region_name",
    type="varchar(50)",          # ← 从 DW 查询 SHOW COLUMNS
    role="dimension",            # ← 从 YAML 配置
    examples=["华东", "华南", "华北"],  # ← 从 DW 查询 SELECT DISTINCT
    description="订单所属的大区名称，如华东、华南等。",
    alias=["地区", "区域", "大区"],
    table_id="dim_region",
    sync=True  # 需要同步到 ES，支持用户通过"华东"这样的值搜索
)

# 订单表的订单金额字段（sync=false，不同步具体数值）
order_amount_column = ColumnInfo(
    id="fact_order.order_amount",
    name="order_amount",
    type="decimal(10,2)",        # ← 从 DW 查询
    role="measure",              # ← 从 YAML 配置（可聚合的数值）
    examples=[1000.00, 2000.00, 1500.00],  # ← 从 DW 查询
    description="订单金额。",
    alias=["销售额", "订单金额", "收入"],
    table_id="fact_order",
    sync=False  # 数值字段，不同步具体值到 ES
)

# 日期表的年份字段
year_column = ColumnInfo(
    id="dim_date.year",
    name="year",
    type="int",
    role="dimension",
    examples=[2023, 2024],
    description="年份。",
    alias=["年", "年份"],
    table_id="dim_date",
    sync=False
)

# 日期表的月份字段
month_column = ColumnInfo(
    id="dim_date.month",
    name="month",
    type="int",
    role="dimension",
    examples=[1, 2, 3, 4],
    description="月份。",
    alias=["月", "月份"],
    table_id="dim_date",
    sync=False
)

# 订单表的外键字段（关联地区表）
region_id_column = ColumnInfo(
    id="fact_order.region_id",
    name="region_id",
    type="int",
    role="foreign_key",  # 外键，用于关联维度表
    examples=[1, 2, 3],
    description="关联地区维度的外键。",
    alias=["地区ID", "区域ID"],
    table_id="fact_order",
    sync=False
)


# ---------- 3. MetricInfo 实例 ----------
# 描述业务概念
gmv_metric = MetricInfo(
    id="GMV",
    name="GMV",
    description="全称Gross Merchandise Value，表示所有订单的成交金额总和。",
    relevant_columns=["fact_order.order_amount"],  # 关联到订单金额字段
    alias=["成交总额", "订单总额"]
)

aov_metric = MetricInfo(
    id="AOV",
    name="AOV",
    description="全称Average Order Value，表示所有订单的成交金额平均值。",
    relevant_columns=["fact_order.order_amount"],
    alias=["平均单价", "平均订单金额"]
)


# ---------- 4. ColumnMetric 实例 ----------
# 记录指标与字段的映射关系
gmv_to_amount = ColumnMetric(
    column_id="fact_order.order_amount",
    metric_id="GMV"
)

aov_to_amount = ColumnMetric(
    column_id="fact_order.order_amount",
    metric_id="AOV"
)


# ---------- 5. ValueInfo 实例 ----------
# 字段的具体取值（只给 sync=true 的字段创建）
region_values = [
    ValueInfo(
        id="dim_region.region_name.华东",
        value="华东",
        column_id="dim_region.region_name"
    ),
    ValueInfo(
        id="dim_region.region_name.华南",
        value="华南",
        column_id="dim_region.region_name"
    ),
    ValueInfo(
        id="dim_region.region_name.华北",
        value="华北",
        column_id="dim_region.region_name"
    ),
]

# 注意：order_amount 字段 sync=false，不创建 ValueInfo


# ============================================================
# 第七部分：实体协作流程 - 从用户问到生成SQL
# ============================================================

"""
用户问题："华东地区2024年1月的GMV是多少？"

执行流程：

┌─────────────────────────────────────────────────────────────────┐
│ 步骤1：解析用户问题，提取关键信息                                │
├─────────────────────────────────────────────────────────────────┤
│ - "华东" → 一个具体的值                                          │
│ - "地区" → 可能对应 region_name 字段                            │
│ - "2024年1月" → year=2024, month=1                             │
│ - "GMV" → 一个指标                                              │
└─────────────────────────────────────────────────────────────────┘
                              ↓
┌─────────────────────────────────────────────────────────────────┐
│ 步骤2：通过 ES 检索 ValueInfo                                   │
├─────────────────────────────────────────────────────────────────┤
│ 输入 "华东"                                                     │
│ 找到 ValueInfo(                                                │
│     id="dim_region.region_name.华东",                          │
│     value="华东",                                              │
│     column_id="dim_region.region_name"  ← 告诉我们这是哪个字段  │
│ )                                                              │
└─────────────────────────────────────────────────────────────────┘
                              ↓
┌─────────────────────────────────────────────────────────────────┐
│ 步骤3：通过 MetricInfo 找到指标对应的字段                        │
├─────────────────────────────────────────────────────────────────┤
│ 输入 "GMV"                                                     │
│ 找到 MetricInfo(                                               │
│     id="GMV",                                                  │
│     relevant_columns=["fact_order.order_amount"]               │
│ )                                                              │
│ → 需要查询 order_amount 字段                                    │
└─────────────────────────────────────────────────────────────────┘
                              ↓
┌─────────────────────────────────────────────────────────────────┐
│ 步骤4：通过 ColumnInfo 获取字段的完整信息                        │
├─────────────────────────────────────────────────────────────────┤
│ region_name_column:                                            │
│   - name="region_name", table_id="dim_region"                  │
│   - type="varchar", role="dimension"                           │
│                                                                 │
│ order_amount_column:                                           │
│   - name="order_amount", table_id="fact_order"                 │
│   - type="decimal", role="measure"                             │
│                                                                 │
│ year_column / month_column:                                    │
│   - table_id="dim_date"                                        │
└─────────────────────────────────────────────────────────────────┘
                              ↓
┌─────────────────────────────────────────────────────────────────┐
│ 步骤5：通过 TableInfo 确定表关联                                 │
├─────────────────────────────────────────────────────────────────┤
│ dim_region_table: region_name 所属表                           │
│ dim_date_table: year/month 所属表                              │
│ fact_order_table: order_amount 所属表                          │
│                                                                 │
│ 通过外键关系确定 JOIN：                                         │
│ - fact_order.region_id = dim_region.region_id                  │
│ - fact_order.date_id = dim_date.date_id                        │
└─────────────────────────────────────────────────────────────────┘
                              ↓
┌─────────────────────────────────────────────────────────────────┐
│ 步骤6：生成 SQL                                                 │
├─────────────────────────────────────────────────────────────────┤
│ SELECT SUM(fact_order.order_amount) AS GMV                     │
│ FROM fact_order                                                │
│ LEFT JOIN dim_region ON fact_order.region_id = dim_region.region_id│
│ LEFT JOIN dim_date ON fact_order.date_id = dim_date.date_id    │
│ WHERE dim_region.region_name = '华东'                          │
│   AND dim_date.year = 2024                                     │
│   AND dim_date.month = 1                                       │
└─────────────────────────────────────────────────────────────────┘
"""


# ============================================================
# 第八部分：各实体存储位置与用途总结
# ============================================================

"""
┌──────────────┬───────────────────┬─────────────────────────────────┐
│ 实体         │ 存储位置          │ 用途                            │
├──────────────┼───────────────────┼─────────────────────────────────┤
│ TableInfo    │ Meta MySQL        │ 知道数据在哪个表                │
│ ColumnInfo   │ Meta MySQL        │ 知道字段的类型和含义            │
│              │ + Qdrant（向量）  │ 支持语义搜索字段                │
│ MetricInfo   │ Meta MySQL        │ 知道业务术语对应哪个字段        │
│ ColumnMetric │ Meta MySQL        │ 持久化指标与字段的映射关系      │
│ ValueInfo    │ Elasticsearch     │ 支持用户通过具体值搜索字段      │
└──────────────┴───────────────────┴─────────────────────────────────┘
"""


# ============================================================
# 第九部分：type 与 role 的来源对比
# ============================================================

"""
┌──────────┬─────────────────────────────────────────────────────────┐
│ 属性     │ 说明                                                    │
├──────────┼─────────────────────────────────────────────────────────┤
│ type     │ 来源：DW（数据仓库），通过 SHOW COLUMNS 查询            │
│          │ 含义：数据库数据类型，描述"数据怎么存"                   │
│          │ 示例：varchar(50), decimal(10,2), int, date            │
│          │ 用途：告诉系统技术上怎么处理（字符串/数值/日期）          │
├──────────┼─────────────────────────────────────────────────────────┤
│ role     │ 来源：YAML配置文件，由用户填写                          │
│          │ 含义：业务角色，描述"数据用来干什么"                     │
│          │ 示例：primary_key, foreign_key, dimension, measure     │
│          │ 用途：告诉系统业务上怎么用（用于分组/用于聚合/用于关联）  │
└──────────┴─────────────────────────────────────────────────────────┘

设计原则：
    能从系统自动获取的真实信息（type、examples），就尽量不让用户手工填写。
    用户只需要填写业务语义（role、description、alias）。
"""


# ============================================================
# 第十部分：快速参考卡片
# ============================================================

"""
【一句话记五个实体】
- TableInfo    → 数据在哪个文件夹
- ColumnInfo   → 文件夹里的文件长什么样
- MetricInfo   → 业务术语对应哪个文件
- ColumnMetric → 在数据库里记下这个对应关系
- ValueInfo    → 文件里具体写了什么值

【一句话记 DW】
DW（数据仓库）存真实业务数据，本系统从 DW 查字段类型和示例值。

【一句话记 type】
type 是数据库数据类型，告诉系统技术上怎么处理这个字段。

【一句话记 role】
role 是字段业务角色，告诉系统业务上怎么用这个字段。

【一句话记 sync】
sync=true 的字段，系统会把它的具体取值同步到 ES，支持用户按值搜索。
"""